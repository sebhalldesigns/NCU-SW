{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "flash-m7",
            "type": "shell",
            "command": "${workspaceFolder}/openocd/bin/openocd.exe",
            "args": [
                "-f", "${workspaceFolder}/openocd/openocd/scripts/board/ncu.cfg",
                "-c", "init; halt; flash write_image erase build/Release/m7/ncu-m7.bin 0x08000000; reset init; resume; shutdown"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "flash-m4",
            "type": "shell",
            "command": "${workspaceFolder}/openocd/bin/openocd.exe",
            "args": [
                "-f", "${workspaceFolder}/openocd/openocd/scripts/board/ncu.cfg",
                "-c", "init; halt; flash write_image erase build/Release/m4/ncu-m4.bin 0x08100000; reset init; resume; shutdown"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "flash-all",
            "type": "shell",
            "command": "${workspaceFolder}/openocd/bin/openocd.exe",
            "args": [
                "-f", "${workspaceFolder}/openocd/openocd/scripts/board/ncu.cfg",
                "-c", "init; halt; flash write_image erase build/Release/m7/ncu-m7.bin 0x08000000; flash write_image erase build/Release/m4/ncu-m4.bin 0x08100000; reset init; resume; shutdown"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake: build",
            "problemMatcher": [],
            "group": "build"
        }
    ]
}